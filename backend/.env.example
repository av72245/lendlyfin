# ── DATABASE ───────────────────────────────────────────────────
# Local development (SQLite — no setup needed)
DATABASE_URL=sqlite:///./lendlyfin.db

# Production (PostgreSQL on Supabase/Railway/Render)
# DATABASE_URL=postgresql://user:password@host:5432/lendlyfin

# ── SECURITY ───────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-before-deployment
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── ADMIN CREDENTIALS ──────────────────────────────────────────
ADMIN_EMAIL=admin@lendlyfin.com.au
ADMIN_PASSWORD=changeme123
BROKER_EMAIL=broker@lendlyfin.com.au
BROKER_PASSWORD=brokerpass123

# ── EMAIL (SendGrid) ───────────────────────────────────────────
# Get free API key at sendgrid.com (100 emails/day free)
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
EMAIL_FROM=hello@lendlyfin.com.au
EMAIL_FROM_NAME=Lendlyfin
BROKER_NOTIFICATION_EMAIL=broker@lendlyfin.com.au

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://lendlyfin.com.au,https://www.lendlyfin.com.au

# ── APP ────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=1.0.0
